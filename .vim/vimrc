Plug 'mattn/emmet-vim'
let g:user_emmet_leader_key='<C-Q>'
Plug 'alvan/vim-closetag'
let g:closetag_filenames = "*.html,*.xhtml,*.phtml,*.php,*.js,*.jsx"
Plug 'turbio/bracey.vim', {'do': 'npm install --prefix server'}
